<nav style="background:#1e40af; padding:16px 40px; display:flex; justify-content:space-between; align-items:center;">
  <div>
    <a href="/" style="color:white; font-weight:bold; text-transform:uppercase; text-decoration:none;">
      DevBlog
    </a>
  </div>

  <div style="display:flex; gap:30px; align-items:center;">
    <% if (typeof user !== 'undefined' && user) { %>
      <span style="color:white; font-weight:bold; text-transform:uppercase;">
        Welcome, <%= user %>
      </span>
      <a href="/admin/logout" style="color:white; font-weight:bold; text-transform:uppercase; text-decoration:none;">
        Logout
      </a>
    <% } else { %>
      <a href="/admin/login" style="color:white; font-weight:bold; text-transform:uppercase; text-decoration:none;">
        Login
      </a>
      <a href="/admin/register" style="color:white; font-weight:bold; text-transform:uppercase; text-decoration:none;">
        Register
      </a>
    <% } %>
  </div>
</nav>

<header class="w-full container mx-auto">
  <div class="flex flex-col items-center py-12">
    <a class="font-bold text-gray-800 uppercase hover:text-gray-700 text-5xl" href="/">
      DevBlog
    </a>
    <p class="text-lg text-gray-600">
      Where Ideas Come to Life
    </p>
  </div>
</header>